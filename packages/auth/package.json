{
  "name": "@easygoal/auth",
  "version": "0.1.0",
  "description": "Auth providers, callbacks e middleware SSO do ecossistema Easy Goal (Next.js + Supabase)",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2",
    "@supabase/ssr": ">=0.5",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2",
    "@supabase/ssr": "^0.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "next": "^14",
    "tsup": "^8",
    "typescript": "^5"
  }
}
