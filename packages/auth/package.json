{
  "name": "@easygoal/auth",
  "version": "1.0.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "./client": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.2.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2",
    "@supabase/ssr": "^0.5",
    "@types/react": "^18",
    "@types/node": "^20",
    "next": "^14",
    "react": "^18",
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  }
